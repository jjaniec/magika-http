{
  "openapi": "3.0.3",
  "info": {
    "title": "magika-http",
    "description": "HTTP microservice wrapper for Google Magika AI-powered file-type detection",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "email": "support@example.com",
      "url": "https://example.com/support"
    }
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Healthz",
        "description": "Health check endpoint.\n\nReturns service status and confirms the Magika model is loaded and ready\nto process requests.",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scan": {
      "post": {
        "tags": [
          "Scan"
        ],
        "summary": "Scan",
        "description": "Identify the content type of an uploaded file using Google Magika.\n\nAccepts any file via multipart/form-data and returns the detected content\ntype together with confidence score and scan duration.",
        "operationId": "scan_scan_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_scan_scan_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_scan_scan_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_scan_scan_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "model_ready": {
            "type": "boolean",
            "title": "Model Ready"
          },
          "model_version": {
            "type": "string",
            "title": "Model Version"
          },
          "magika_version": {
            "type": "string",
            "title": "Magika Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "model_ready",
          "model_version",
          "magika_version"
        ],
        "title": "HealthResponse"
      },
      "ScanResult": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "mime_type": {
            "type": "string",
            "title": "Mime Type"
          },
          "group": {
            "type": "string",
            "title": "Group"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "extensions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Extensions"
          },
          "is_text": {
            "type": "boolean",
            "title": "Is Text"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "scan_duration_ms": {
            "type": "number",
            "title": "Scan Duration Ms"
          }
        },
        "type": "object",
        "required": [
          "ok",
          "label",
          "mime_type",
          "group",
          "description",
          "extensions",
          "is_text",
          "score",
          "scan_duration_ms"
        ],
        "title": "ScanResult"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ]
}